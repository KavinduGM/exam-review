# ─────────────────────────────────────────────────────────────────────────────
# Web Site Auditor — environment configuration
# Copy to .env (local) or set these as Dokploy secrets (production).
# ─────────────────────────────────────────────────────────────────────────────

# --- Our master database (Postgres) ---
# Local docker-compose default is below. In Dokploy, point at the auditor-db service.
DATABASE_URL="postgresql://auditor:auditor@localhost:5432/auditor?schema=public"

# --- Queue / scheduler (Redis) ---
REDIS_URL="redis://localhost:6379"

# --- Client source databases (READ-ONLY user: auditor_ro, SELECT only) ---
# Use the Dokploy INTERNAL host (service container name) in production, e.g.:
#   onlineexam-onlineexamdb-iqw9vd
# Leave any of these blank to disable DB cross-validation for that source
# (the system falls back to probing links by incrementing set/part until 404).

# Timed exams -> onlineexamtest.com
SRC_TIMED_HOST=""
SRC_TIMED_PORT="3306"
SRC_TIMED_USER="auditor_ro"
SRC_TIMED_PASSWORD=""
SRC_TIMED_DATABASE="onlineexam_db"

# New practice -> questions.*  (exam_db)
SRC_PRACTICE_NEW_HOST=""
SRC_PRACTICE_NEW_PORT="3306"
SRC_PRACTICE_NEW_USER="auditor_ro"
SRC_PRACTICE_NEW_PASSWORD=""
SRC_PRACTICE_NEW_DATABASE="exam_db"

# Old practice -> answers.*  (answers_db)
SRC_PRACTICE_OLD_HOST=""
SRC_PRACTICE_OLD_PORT="3306"
SRC_PRACTICE_OLD_USER="auditor_ro"
SRC_PRACTICE_OLD_PASSWORD=""
SRC_PRACTICE_OLD_DATABASE="answers_db"

# --- AI review (Anthropic) ---
ANTHROPIC_API_KEY=""
# Cheap model for Tier-2 triage; stronger model for flagged pages.
ANTHROPIC_TRIAGE_MODEL="claude-haiku-4-5-20251001"
ANTHROPIC_REVIEW_MODEL="claude-sonnet-4-6"

# --- Email alerts (Resend) ---
RESEND_API_KEY=""
ALERT_FROM="alerts@yourdomain.com"          # must be on a Resend-verified domain
ALERT_TO="kavindu@groovymark.com"           # comma-separated for multiple recipients

# --- Dashboard auth (single admin) ---
ADMIN_EMAIL="kavindu@groovymark.com"
ADMIN_PASSWORD="change-me"                    # used to log in to the dashboard
AUTH_SECRET="generate-a-long-random-string"   # signs the session cookie

# --- YouTube-description API (/api/description/*) ---
DESCRIPTION_API_KEY=""                          # secret key your description generator sends

# --- Scheduling (cron expressions, server timezone) ---
TZ="UTC"
UPTIME_CRON="*/10 * * * *"                     # every 10 minutes
COLLECT_CRON="0 3 * * *"                       # daily 03:00 (backfills exam names as added)
AUDIT_CRON="0 4 * * 1"                         # weekly, Monday 04:00

# --- Tuning ---
HTTP_CONCURRENCY="8"                           # parallel HTTP checks
PLAYWRIGHT_CONCURRENCY="2"                     # parallel browser pages (KVM2-safe)
HTTP_TIMEOUT_MS="20000"
AUDIT_SAMPLE_PCT="10"                          # % of healthy pages to AI-review each run
SCREENSHOT_DIR="./data/screenshots"
PUBLIC_API_BASE="http://localhost:3000"

# Hosts that rate-limit bursts (fetched serially with a 3s gap)
SLOW_HOSTS="onlinedegreeblogs.com"

# --- Broken-link report loop with the description system ---
DESCRIPTION_WEBHOOK_URL=""                     # we POST link.recovered events here
DESCRIPTION_WEBHOOK_KEY=""                     # sent as x-api-key on that webhook
REPORT_ESCALATION_HOURS="24"                   # email admin if a reported link stays down
