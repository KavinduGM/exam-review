{
  "name": "web-site-auditor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Link Registry + Auditor for exam-prep sites: collects exam links, monitors uptime, and runs tiered AI page reviews.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start -p ${PORT:-3000}",
    "worker": "tsx src/worker.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "collect": "tsx src/scripts/collect-cli.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@prisma/client": "^6.2.1",
    "bullmq": "^5.34.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "fast-xml-parser": "^4.5.1",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "mysql2": "^3.12.0",
    "next": "^15.1.4",
    "pino": "^9.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^4.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "pino-pretty": "^13.0.0",
    "playwright": "1.61.1",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "ioredis": "^5.4.2"
  }
}
